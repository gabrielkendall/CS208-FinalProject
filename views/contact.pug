extends layout

//- Add a function to sonstruct the Logo
mixin donutLogo(themeClass)
  .logo(class=themeClass)
    svg.logo-graphic(viewBox="0 0 400 260" aria-hidden="true")
      g(fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="sharp")
        path(d="M60 170 C85 12 315 12 340 170")
        path(d="M145 170 C165 118 235 118 255 170")

        line(x1="87" y1="130" x2="93" y2="142")
        line(x1="109" y1="165" x2="121" y2="160")
        line(x1="107" y1="101" x2="118" y2="92")
        line(x1="129" y1="125" x2="141" y2="128")
        line(x1="150" y1="73" x2="157" y2="84")
        line(x1="179" y1="104" x2="179" y2="118")
        line(x1="194" y1="72" x2="206" y2="76")
        line(x1="237" y1="77" x2="250" y2="70")
        line(x1="225" y1="115" x2="233" y2="105")
        line(x1="275" y1="90" x2="278" y2="104")
        line(x1="257" y1="130" x2="269" y2="136")
        line(x1="286" y1="165" x2="298" y2="159")
        line(x1="317" y1="136" x2="317" y2="149")

        line(x1="60" y1="230" x2="145" y2="230")
        line(x1="255" y1="230" x2="340" y2="230")

    h1.logo-name Downtown Donuts
    p.logo-since Since 1992


block content

  //- Import fonts
  head
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Italianno&family=Montserrat:wght@400&display=swap" rel="stylesheet")

  body 
    //- Add logo as upper banner
    section.section-dark
      +donutLogo('logo-dark')

    //- Table of Links
    section.links 
      table
        tr
          td 
            a(href="/") Home
          td 
            a(href="/menu") Menu
          td 
            a(href="/contact") Contact Us
          td 
            a(href="/reviews") Customer Comments

    //- Main content section ???
    section.main-content
      h1 Contact Us
      
