extends layout

//- Add a function to construct the Logo. Photoshop was used for pixel positions.
mixin donutLogo(themeClass)
  .logo(class=themeClass)
    svg.logo-graphic(viewBox="0 0 400 260" aria-hidden="true")
      g(fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="sharp")
        path(d="M60 170 C85 12 315 12 340 170")
        path(d="M145 170 C165 118 235 118 255 170")

        line(x1="87" y1="130" x2="93" y2="142")
        line(x1="109" y1="165" x2="121" y2="160")
        line(x1="107" y1="101" x2="118" y2="92")
        line(x1="129" y1="125" x2="141" y2="128")
        line(x1="150" y1="73" x2="157" y2="84")
        line(x1="179" y1="104" x2="179" y2="118")
        line(x1="194" y1="72" x2="206" y2="76")
        line(x1="237" y1="77" x2="250" y2="70")
        line(x1="225" y1="115" x2="233" y2="105")
        line(x1="275" y1="90" x2="278" y2="104")
        line(x1="257" y1="130" x2="269" y2="136")
        line(x1="286" y1="165" x2="298" y2="159")
        line(x1="317" y1="136" x2="317" y2="149")

        line(x1="60" y1="230" x2="145" y2="230")
        line(x1="255" y1="230" x2="340" y2="230")

    h1.logo-name Downtown Donuts
    p.logo-since Since 1992


block content

  //- Import fonts
  head
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Italianno&family=Montserrat:wght@400&display=swap" rel="stylesheet")

  body 
    //- Add logo as upper banner
    section.section-dark
      +donutLogo('logo-dark')

    //- Top Navigation Bar
    section.links 
      table
        tr
          td 
            a(href="/") Home
          td 
            a(href="/menu") Menu
          td 
            a(href="/contact") Contacts
          td 
            a(href="/reviews") Reviews

    .divider
    //- Main content section
    section.menu
      h1 Menu

      //- A grid of 9 images with their corresponding alt text and descriptor.
      table

        //- Row 1
        tr 
          td 
            img(src="images/Bismark.jpg", alt="Bismark")
            div Bismark
            div $2.75
          td 
            img(src="images/Fritter.jpg", alt="Fritter")
            div Fritter
            div $3.25
          td 
            img(src="images/Beignet.jpg", alt="Beignet")
            div Beignet
            div $2.50

        //- Row 2
        tr 
          td 
            img(src="images/Boston-cream-donut.jpg", alt="Boston Cream")
            div Boston Cream
            div $2.85
          td 
            img(src="images/Bear-claw.jpg", alt="Bear Claw")
            div Bear Claw
            div $3.50
          td 
            img(src="images/Paczki.jpg", alt="Paczki")
            div Paczki
            div $3.75

        //- Row 3
        tr 
          td 
            img(src="images/Old-fashioned-donut.jpg", alt="Old Fashioned")
            div Old Fashioned
            div $2.25
          td 
            img(src="images/Sugar-donut.jpg", alt="Sugar Dusted")
            div Sugar Dusted
            div $2.00
          td 
            img(src="images/Donut-holes.jpg", alt="Donut Holes")
            div Donut Holes
            div $1.75 (per dozen)


    //- A space then the Footer.
    .divider

    footer.footer
      .footer-content
        p © 2026 Downtown Donuts
        p 17265 Main Street, Boise
        p (555) 123-4567
        p Find Us:
        a(href="http://www.doordash.com") Doordash
        a(href="http://www.ubereats.com") UberEats