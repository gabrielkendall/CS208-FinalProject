extends layout



block content
  head
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Italianno&family=Montserrat:wght@400&display=swap" rel="stylesheet")

  body 
    // Dark version
    .section-dark
      .logo.logo-dark
        svg.logo-graphic(viewBox="0 0 400 260" aria-hidden="true")
          g(fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="sharp")
            path(d="M60 170 C85 12 315 12 340 170")
            path(d="M145 170 C165 118 235 118 255 170")


            line(x1="87" y1="130" x2="93" y2="142")
            line(x1="109" y1="165" x2="121" y2="160")
            line(x1="107" y1="101" x2="118" y2="92")
            line(x1="129" y1="125" x2="141" y2="128")
            line(x1="150" y1="73" x2="157" y2="84")
            line(x1="179" y1="104" x2="179" y2="118")
            line(x1="194" y1="72" x2="206" y2="76")
            line(x1="237" y1="77" x2="250" y2="70")
            line(x1="225" y1="115" x2="233" y2="105")
            line(x1="275" y1="90" x2="278" y2="104")
            line(x1="257" y1="130" x2="269" y2="136")
            line(x1="286" y1="165" x2="298" y2="159")
            line(x1="317" y1="136" x2="317" y2="149")


            line(x1="60" y1="230" x2="145" y2="230")
            line(x1="255" y1="230" x2="340" y2="230")

        h1.logo-name Downtown Donuts
        p.logo-since Since 1992

    // Light version
    .section-light
      .logo.logo-light
        svg.logo-graphic(viewBox="0 0 400 260" aria-hidden="true")
          g(fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round")
            path(d="M60 170 A140 140 0 0 1 340 170")
            path(d="M145 170 A55 55 0 0 1 255 170")
            line(x1="60" y1="205" x2="145" y2="205")
            line(x1="255" y1="205" x2="340" y2="205")
            line(x1="95" y1="120" x2="105" y2="130")
            line(x1="125" y1="95" x2="133" y2="110")
            line(x1="145" y1="135" x2="158" y2="138")
            line(x1="175" y1="80" x2="190" y2="84")
            line(x1="190" y1="112" x2="190" y2="126")
            line(x1="230" y1="88" x2="245" y2="75")
            line(x1="240" y1="125" x2="252" y2="112")
            line(x1="275" y1="95" x2="282" y2="112")
            line(x1="305" y1="135" x2="305" y2="150")
            line(x1="112" y1="160" x2="128" y2="154")

        h1.logo-name Downtown Donuts
        p.logo-since Since 1992


  h1= title
  p Welcome to #{title}
  ol
  each val in todos
    li
      span= val.task + ' - '
      if val.completed > 0
        span Completed
      else
        span Not Completed
      form(method='POST' action='/delete')
        input(type='hidden', name='id', value=val.id)
        button(type='submit') Delete

  hr
  h2 Add a new task
  form(method='POST' action='/create')
    label(for='task') Task:
    input(type='text', name='task', id='task', required)
    button(type='submit') Create Task
