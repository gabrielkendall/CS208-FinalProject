extends layout

//- Add a function to construct the Logo. Photoshop was used for pixel positions.
mixin donutLogo(themeClass)
  .logo(class=themeClass)
    svg.logo-graphic(viewBox="0 0 400 260" aria-hidden="true")
      g(fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="sharp")
        path(d="M60 170 C85 12 315 12 340 170")
        path(d="M145 170 C165 118 235 118 255 170")

        line(x1="87" y1="130" x2="93" y2="142")
        line(x1="109" y1="165" x2="121" y2="160")
        line(x1="107" y1="101" x2="118" y2="92")
        line(x1="129" y1="125" x2="141" y2="128")
        line(x1="150" y1="73" x2="157" y2="84")
        line(x1="179" y1="104" x2="179" y2="118")
        line(x1="194" y1="72" x2="206" y2="76")
        line(x1="237" y1="77" x2="250" y2="70")
        line(x1="225" y1="115" x2="233" y2="105")
        line(x1="275" y1="90" x2="278" y2="104")
        line(x1="257" y1="130" x2="269" y2="136")
        line(x1="286" y1="165" x2="298" y2="159")
        line(x1="317" y1="136" x2="317" y2="149")

        line(x1="60" y1="230" x2="145" y2="230")
        line(x1="255" y1="230" x2="340" y2="230")

    h1.logo-name Downtown Donuts
    p.logo-since Since 1992


block content

  //- Import fonts
  head
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Italianno&family=Montserrat:wght@400&display=swap" rel="stylesheet")

  body 
    //- Add logo as upper banner
    section.section-dark
      +donutLogo('logo-dark')

    //- Top Navigation Bar
    section.links 
      table
        tr
          td 
            a(href="/") Home
          td 
            a(href="/menu") Menu
          td 
            a(href="/contact") Contacts
          td 
            a(href="/reviews") Reviews

    .divider
    //- Main content section ???
    section.main-content
      h1 Our Story
      p Downtown Donuts began in 1992 with a simple idea: make great donuts, serve them fresh, and become part of the neighborhood. What started as a small shop in Boise quickly turned into a local staple, built on early mornings, hand-cut dough, and recipes that were refined one batch at a time.
      p From the beginning, the focus has been consistency and quality. Every donut is still made with care, using time-tested methods that haven't changed much over the years. The goal was never to chase trends, but to get the classics right—and to make sure customers could count on the same familiar taste every time they walked through the door.
      p Over the decades, Downtown Donuts has grown alongside Boise. Generations of customers have made it part of their routines—whether it's a quick stop before work, a weekend tradition, or a box shared with friends and family. That connection to the community remains at the heart of everything.
      p Today, Downtown Donuts continues to do what it's always done: show up early, make donuts from scratch, and serve Boise one fresh batch at a time.




    //- A space then the Footer.
    .divider

    footer.footer
      .footer-content
        p © 2026 Downtown Donuts
        p 17265 Main Street, Boise
        p (555) 123-4567
        .divider
        p Find Us:
        p 
          a(href="http://www.doordash.com" target="_blank") Doordash
        p 
          a(href="http://www.ubereats.com" target="_blank") UberEats


      
